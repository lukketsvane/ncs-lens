# Supabase Configuration
# Get these values from your Supabase project settings (hosted),
# or from `npm run db:status` after `npm run db:start` (local stack).
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Supabase Service Role Key (server-side only, for admin operations)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# --- Local development with the Supabase CLI (`npm run db:start`) ---
# Use the local stack instead of a hosted project:
#   VITE_SUPABASE_URL=http://127.0.0.1:54321
# Then run `npm run db:status` and copy the printed "anon key" and
# "service_role key" into VITE_SUPABASE_ANON_KEY / SUPABASE_SERVICE_ROLE_KEY above.
# (These local keys are the same fixed defaults on every machine.)

# OpenAI API Key
OPENAI_API_KEY=your_openai_api_key

# Vipps Login Configuration
VIPPS_CLIENT_ID=your_vipps_client_id
VIPPS_CLIENT_SECRET=your_vipps_client_secret
VIPPS_SUBSCRIPTION_KEY=your_vipps_subscription_key
VIPPS_MSN=your_vipps_merchant_serial_number
VIPPS_API_URL=https://api.vipps.no
